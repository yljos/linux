# 基础路径配置
BASE_DIR=.
TEMPLATE_PATH_pc=b.yaml
TEMPLATE_PATH_shouji=b_shouji.yaml
 

# 请求配置
USER_AGENT=clash verge
# 上游 URL 文件（必填，无扩展名的文本文件，内含 URL 第一行）
MITCE_URL_FILE=mitce
BAJIE_URL_FILE=bajie

# 访问密钥原始值的 SHA256（echo -n 'your_long_random_key' | sha256sum | cut -d' ' -f1）
ACCESS_KEY_SHA256=51ef50ce29aa4cf089b9b076cb06e30445090b323f0882f1251c18a06fc228ed
CACHE_DURATION=300
HYSTERIA2_UP=40 Mbps
HYSTERIA2_DOWN=200 Mbps
HYSTERIA2_UP_M=20 Mbps
HYSTERIA2_DOWN_M=40 Mbps
INCLUDED_HEADERS=Subscription-Userinfo
 

# 节点替换功能配置
ENABLE_NODE_REPLACEMENT=false
CLIENT_FINGERPRINT=firefox

# 节点关键字筛选（逗号分隔，仅保存包含这些片段的节点名称）
NODE_KEYWORDS=US,HK,SG,JP,美国,香港,新加坡,日本
# 服务器配置
DEBUG=false
PORT=5002
HOST=0.0.0.0
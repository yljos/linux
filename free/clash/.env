# .env 文件
# 配置 Clash 订阅生成器的参数
USER_AGENT = clash verge
# 访问控制密钥 (用于/mitce?key=...等路径的访问控制)
ACCESS_KEY_SHA256=51ef50ce29aa4cf089b9b076cb06e30445090b323f0882f1251c18a06fc228ed
# 或者存储原始密钥，然后在代码中计算 SHA256，但为了安全，推荐直接存储散列值

# Hysteria2 速率限制 (PC 端)
HYSTERIA2_UP="40 Mbps"
HYSTERIA2_DOWN="200 Mbps"

# Hysteria2 速率限制 (移动端)
HYSTERIA2_UP_M="20 Mbps"
HYSTERIA2_DOWN_M="40 Mbps"

# 节点过滤关键词
# 注意：列表或复杂结构可能需要特殊处理，但对于简单逗号分隔的字符串，可以这样写
NODE_KEYWORDS=US,HK,Hong Kong,Singapore,Japan,United States,SG,JP,美国,香港,新加坡,日本
NODE_EXCLUDE_KEYWORDS=官网,流量,倍率,剩余,10,Australia,到期

# 节点替换开关
ENABLE_NODE_REPLACEMENT=False

# VLESS 客户端指纹
CLIENT_FINGERPRINT=firefox

# 要包含的上游 Headers (以逗号分隔)
INCLUDED_HEADERS=Subscription-Userinfo
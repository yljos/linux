# Basic system commands
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias c="clear"
alias ..='cd ..'

# System operations
alias P="sleep 60 && shutdown now"
alias R="systemctl reboot"
alias rsyncdir="rsync -avzh --delete" 

# Volume control
alias volup="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
alias voldown="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"

# GPG as SSH agent
export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)

# NFS4 mount function
mount-data() {
    if ! mountpoint -q /data; then
        sudo mount -t nfs4 nas:/data /data
    fi
}

# Check SSH agent status for prompt decoration
_ssh_status() {
    if ssh-add -l >/dev/null 2>&1; then
        echo -ne "\001\e[38;5;214m\002*\001\e[0m\002"
    fi
}

# Scripts and programs
x() {
    dbus-run-session bash -c "/home/huai/.config/dwl/dwl_status.sh | dwl"
}
alias win="/usr/bin/bash /home/huai/.config/windows.sh"

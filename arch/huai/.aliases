# Basic system commands
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias c="clear"
alias ..='cd ..'

# System operations
alias P="sleep 60 && shutdown now"
alias R="systemctl reboot"
alias rsyncdir="rsync -avzh --delete" 

# Volume control
alias volup="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
alias voldown="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"

# NFS4 mount function
mount-data() {
    if ! mountpoint -q /data; then
        sudo mount -t nfs4 10.0.0.21:/data /data
    fi
}

alias win="/usr/bin/bash /home/huai/.config/win.sh"
alias wol="/usr/bin/bash /home/huai/.config/wol.sh"
alias x="startx"
alias y="/usr/bin/bash /home/huai/.config/status.sh | dwl"
alias np="/usr/bin/bash /home/huai/.config/wallpaper.sh"
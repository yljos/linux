# cloudflared 访问远程服务器
Host cloud
  ServerAliveInterval 60	
  HostName ssh.202309.xyz
  User root
  ProxyCommand cloudflared access ssh --hostname %h
  
# OpenWRT 主路由
Host openwrt
  HostName 192.168.31.1
  User root
  IdentityAgent /run/user/1000/gnupg/S.gpg-agent.ssh
  # 强制只使用 Agent 提供的身份
  IdentitiesOnly yes
  # 尝试排除可能干扰的默认私钥文件，防止 SSH 客户端查找并干扰 Agent
  IdentityFile none
# AX6S 旁路由
Host ax6s
  HostName 192.168.31.2
  User root

